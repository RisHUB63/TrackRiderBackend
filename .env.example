# Full URL takes priority — if set, individual creds below are ignored
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Fallback creds (used only if DATABASE_URL is not set)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=app_db

# Redis — full URL takes priority, fallback to host/port/db
REDIS_URL=redis://default:password@host:port

JWT_SECRET_KEY=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
WS_TOKEN_EXPIRE_MINUTES=5
DEBUG=true
